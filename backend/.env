# Used by the `query!` macros at compile time (see `sqlx.toml`).
SERVER_DATABASE_URL=postgres://postgres:password@localhost:5432/air_db

# `#[sqlx::test]`'s runtime harness reads DATABASE_URL directly and ignores
# `sqlx.toml`'s `database-url-var`, so it must be set as well for tests.
DATABASE_URL=postgres://postgres:password@localhost:5432/air_db
