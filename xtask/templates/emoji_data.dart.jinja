/// `(category name, its emojis)` indexed by category id, in canonical order then
/// sort order.
const List<(String, List<Emoji>)> emojisByCategory = [
{%- for category in categories %}
  ({{ category.name }}, [
  {%- for emoji in category.emojis %}
  {%- if emoji.variations.is_empty() %}
    Emoji('{{ emoji.escape }}', '{{ emoji.short_name }}'),
  {%- else %}
    Emoji('{{ emoji.escape }}', '{{ emoji.short_name}}', {
    {%- for variation in emoji.variations %}
      '{{ variation.tone }}': '{{ variation.glyph }}',
    {%- endfor %}
